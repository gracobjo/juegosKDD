# Steam Web API — obtener en: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=TU_STEAM_API_KEY_AQUI

# Kaggle — datasets del recomendador (kagglehub / CLI)
# Token API (recomendado para kagglehub): https://www.kaggle.com/settings → API
KAGGLE_API_TOKEN=
# O credenciales clásicas (username + key; también sirven para ~/.kaggle/kaggle.json)
KAGGLE_USERNAME=
KAGGLE_KEY=
# Forzar solo CLI antigua: USE_KAGGLE_CLI_ONLY=1

# RAWG API — obtener en: https://rawg.io/apidocs (opcional)
RAWG_API_KEY=

# Kafka
KAFKA_BOOTSTRAP=localhost:9092

# Cassandra
CASSANDRA_HOST=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=gaming_kdd
CASSANDRA_REC_KEYSPACE=gaming_recommender

# Hive
HIVE_HOST=localhost
HIVE_PORT=10000
# Loader Spark (1_ingesta/kaggle_to_hive/loader.py): metastore Thrift del cluster.
# Si está vacío, Spark usa Derby embebido bajo .spark_loader_metastore/ (no ~/.hive_metastore).
# HIVE_METASTORE_URIS=thrift://localhost:9083
# SPARK_WAREHOUSE_DIR=/ruta/absoluta/spark-warehouse

# API REST
API_HOST=0.0.0.0
API_PORT=8000
